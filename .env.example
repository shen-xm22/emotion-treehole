# ─── 情绪树洞 — 环境变量配置 ─────────────────────────────
# 复制此文件为 .env 并填写实际值（仅本地开发用）
# Render 上请在 Dashboard → Environment 中逐一设置

# ⚠️ 必须设置 ⚠️

# DeepSeek API Key（从 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Supabase service_role key（从 Supabase Dashboard → Settings → API → service_role key 获取）
SUPABASE_SERVICE_KEY=eyJh...

# JWT 签名密钥（至少 32 字符随机字符串）
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-32-char-random-secret-here

# ─── 可选 ───────────────────────────────────────────────

# Supabase 项目 URL（已内置默认值，一般无需修改）
# SUPABASE_URL=https://your-project.supabase.co
